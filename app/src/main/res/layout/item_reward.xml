<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp">

    <ImageView
        android:id="@+id/ivRewardIcon"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:scaleType="centerCrop"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        tools:src="@drawable/ic_reward_placeholder"/>

    <TextView
        android:id="@+id/tvRewardName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="4dp"
        android:text="Reward Name"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#222222"
        app:layout_constraintTop_toTopOf="@+id/ivRewardIcon"
        app:layout_constraintStart_toEndOf="@+id/ivRewardIcon"
        app:layout_constraintEnd_toStartOf="@+id/tvRewardCost"/>

    <TextView
        android:id="@+id/tvRewardDescription"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="4dp"
        android:text="Reward Description"
        android:textSize="14sp"
        android:textColor="#888888"
        app:layout_constraintTop_toBottomOf="@+id/tvRewardName"
        app:layout_constraintStart_toEndOf="@+id/ivRewardIcon"
        app:layout_constraintEnd_toStartOf="@+id/tvRewardCost"/>

    <TextView
        android:id="@+id/tvRewardCost"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="8dp"
        android:text="100 Coins"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/blue"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/tvRewardName"
        app:layout_constraintBottom_toBottomOf="@+id/tvRewardDescription"/>

</androidx.constraintlayout.widget.ConstraintLayout>
