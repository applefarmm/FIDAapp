<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvDialogTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Linked Accounts"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/blue"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <LinearLayout
        android:id="@+id/llGoogleAccount"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:background="@drawable/bg_rounded_card"
        app:layout_constraintTop_toBottomOf="@+id/tvDialogTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/ivGoogleIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_google"/>

        <TextView
            android:id="@+id/tvGoogleStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="Google"
            android:textSize="16sp"/>

        <Button
            android:id="@+id/btnGoogleAction"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Link"
            android:textAllCaps="false"
            android:textSize="12sp"
            android:backgroundTint="@color/blue"
            app:cornerRadius="6dp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/llFacebookAccount"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:background="@drawable/bg_rounded_card"
        app:layout_constraintTop_toBottomOf="@+id/llGoogleAccount"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/ivFacebookIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_facebook"/>

        <TextView
            android:id="@+id/tvFacebookStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="Facebook"
            android:textSize="16sp"/>

        <Button
            android:id="@+id/btnFacebookAction"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Link"
            android:textAllCaps="false"
            android:textSize="12sp"
            android:backgroundTint="@color/blue"
            app:cornerRadius="6dp"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tvEmailProvider"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Email/Password: Always linked"
        android:textSize="14sp"
        android:textColor="#888888"
        app:layout_constraintTop_toBottomOf="@+id/llFacebookAccount"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/btnClose"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginTop="24dp"
        android:text="Close"
        android:textAllCaps="false"
        android:backgroundTint="#888888"
        app:cornerRadius="8dp"
        app:layout_constraintTop_toBottomOf="@+id/tvEmailProvider"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>