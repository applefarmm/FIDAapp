<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvRunDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="2023-10-27 10:30 AM"
        android:textSize="14sp"
        android:textColor="#888888"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <TextView
        android:id="@+id/tvRunDetails"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Distance: 5.00 km | Duration: 30:00"
        android:textSize="16sp"
        android:textColor="#222222"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvRunDate"
        app:layout_constraintEnd_toStartOf="@+id/tvGoalStatus"/>

    <TextView
        android:id="@+id/tvGoalStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Goal Achieved!"
        android:textSize="14sp"
        android:textStyle="italic"
        android:textColor="@color/blue"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/tvRunDetails"
        app:layout_constraintBottom_toBottomOf="@+id/tvRunDetails"/>

</androidx.constraintlayout.widget.ConstraintLayout>
