<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    tools:context=".PreRunActivity">

    <TextView
        android:id="@+id/tvPreRunTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="80dp"
        android:text="Set Your Goal"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="@color/blue"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvGoalTypeLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:text="Goal Type:"
        android:textSize="18sp"
        android:textColor="#888888"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/rgGoalType"
        app:layout_constraintTop_toBottomOf="@+id/tvPreRunTitle"/>

    <RadioGroup
        android:id="@+id/rgGoalType"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintStart_toEndOf="@+id/tvGoalTypeLabel"
        app:layout_constraintTop_toTopOf="@+id/tvGoalTypeLabel"
        app:layout_constraintEnd_toStartOf="@+id/tvGoalValueLabel"
        android:layout_marginTop="32dp">

        <RadioButton
            android:id="@+id/rbDistance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Distance (km)"
            android:textSize="16sp"
            android:checked="true" />

        <RadioButton
            android:id="@+id/rbTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Time (minutes)"
            android:textSize="16sp"
            android:layout_marginTop="12dp"/>

        <RadioButton
            android:id="@+id/rbCalories"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Calories (kcal)"
            android:textSize="16sp"
            android:layout_marginTop="12dp"/>
    </RadioGroup>

    <TextView
        android:id="@+id/tvGoalValueLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Goal Value:"
        android:textSize="18sp"
        android:textColor="#888888"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/etGoalValue"
        app:layout_constraintTop_toBottomOf="@+id/rgGoalType"/>

    <EditText
        android:id="@+id/etGoalValue"
        android:layout_width="80dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/edittext_border"
        android:hint="5"
        android:inputType="numberDecimal"
        android:padding="12dp"
        android:gravity="center"
        app:layout_constraintStart_toEndOf="@+id/tvGoalValueLabel"
        app:layout_constraintEnd_toStartOf="@+id/tvKm"
        app:layout_constraintTop_toBottomOf="@+id/rgGoalType"/>

    <TextView
        android:id="@+id/tvKm"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="km"
        android:textSize="20sp"
        android:textColor="#222222"
        app:layout_constraintStart_toEndOf="@+id/etGoalValue"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/etGoalValue"
        app:layout_constraintBottom_toBottomOf="@+id/etGoalValue"
        android:layout_marginStart="8dp"/>

    <Button
        android:id="@+id/btnStartRun"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:backgroundTint="@color/blue"
        android:text="Start Run"
        android:textAllCaps="false"
        android:textSize="16sp"
        app:cornerRadius="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/etGoalValue"
        android:layout_marginTop="48dp"/>

    <TextView
        android:id="@+id/tvBackToHome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Back to Home"
        android:textColor="@color/blue"
        android:textSize="15sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnStartRun"/>

</androidx.constraintlayout.widget.ConstraintLayout>
