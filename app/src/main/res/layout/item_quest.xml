<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Quest Icon -->
        <TextView
            android:id="@+id/tvQuestIcon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="🏃"
            android:textSize="28sp"
            android:gravity="center"
            android:background="@drawable/bg_rounded_card" />

        <!-- Quest Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/tvQuestType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DAILY"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/blue"
                android:background="#E8F0FF"
                android:padding="2dp" />

            <TextView
                android:id="@+id/tvQuestTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Daily Run"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#222222"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/tvQuestDescription"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Complete a 30-minute run"
                android:textSize="13sp"
                android:textColor="#888888" />

            <TextView
                android:id="@+id/tvQuestRewards"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+50 XP | +20 🪙"
                android:textSize="12sp"
                android:textColor="@color/yellow"
                android:textStyle="bold"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Accept Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAcceptQuest"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="Accept"
            android:textSize="12sp"
            android:backgroundTint="@color/blue"
            android:textColor="@color/white"
            app:cornerRadius="8dp" />

    </LinearLayout>
</androidx.cardview.widget.CardView>