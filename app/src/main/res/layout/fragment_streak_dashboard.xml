<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    tools:context=".fragments.StreakDashboardFragment">

    <TextView
        android:id="@+id/tvStreakDashboardTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Your Streaks"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/blue"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvCurrentStreakLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Current Streak:"
        android:textSize="18sp"
        android:textColor="#222222"
        app:layout_constraintTop_toBottomOf="@+id/tvStreakDashboardTitle"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/tvCurrentStreak"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:text="15 days"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/green_500"
        app:layout_constraintTop_toTopOf="@+id/tvCurrentStreakLabel"
        app:layout_constraintStart_toEndOf="@+id/tvCurrentStreakLabel"/>

    <TextView
        android:id="@+id/tvLongestStreakLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Longest Streak:"
        android:textSize="18sp"
        android:textColor="#222222"
        app:layout_constraintTop_toBottomOf="@+id/tvCurrentStreak"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/tvLongestStreak"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:text="30 days"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#888888"
        app:layout_constraintTop_toTopOf="@+id/tvLongestStreakLabel"
        app:layout_constraintStart_toEndOf="@+id/tvLongestStreakLabel"/>

    <ImageView
        android:id="@+id/ivStreakShields"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginTop="32dp"
        android:src="@drawable/ic_streak_shield" // Assuming you have this drawable
        app:layout_constraintTop_toBottomOf="@+id/tvLongestStreak"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/tvStreakShieldCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:text="x 3"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/blue"
        app:layout_constraintTop_toTopOf="@+id/ivStreakShields"
        app:layout_constraintBottom_toBottomOf="@+id/ivStreakShields"
        app:layout_constraintStart_toEndOf="@+id/ivStreakShields"/>

    <TextView
        android:id="@+id/tvStreakCalendarLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Streak Calendar"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#222222"
        app:layout_constraintTop_toBottomOf="@+id/ivStreakShields"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Placeholder for a calendar view or heatmap -->
    <TextView
        android:layout_width="0dp"
        android:layout_height="150dp"
        android:layout_marginTop="8dp"
        android:text="Calendar view will be implemented here."
        android:textSize="14sp"
        android:textColor="#888888"
        android:gravity="center"
        android:background="@drawable/edittext_border"
        app:layout_constraintTop_toBottomOf="@+id/tvStreakCalendarLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
