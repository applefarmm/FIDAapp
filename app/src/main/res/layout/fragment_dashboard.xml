<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvGreeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Good morning!"
                    android:textSize="14sp"
                    android:textColor="#888888" />

                <TextView
                    android:id="@+id/tvUsername"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Athlete"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#222222" />
            </LinearLayout>

            <!-- Streak badge -->
            <LinearLayout
                android:id="@+id/streakBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_rounded_card"
                android:padding="8dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔥"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/tvStreak"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/blue"
                    android:layout_marginStart="4dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- XP Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="@color/blue">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:id="@+id/tvLevel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Level 1"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/white" />

                    <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />

                    <TextView
                        android:id="@+id/tvCoins"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🪙 0"
                        android:textSize="14sp"
                        android:textColor="@color/white" />
                </LinearLayout>

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/xpBar"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:progress="0"
                    app:trackCornerRadius="4dp"
                    app:indicatorColor="@color/yellow"
                    app:trackColor="#5566CC" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp">

                    <TextView
                        android:id="@+id/tvXp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 XP"
                        android:textSize="12sp"
                        android:textColor="@color/white" />

                    <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />

                    <TextView
                        android:id="@+id/tvMaxXp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="100 XP"
                        android:textSize="12sp"
                        android:textColor="@color/white" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Today's Activities -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Today's Activities"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#222222"
            android:layout_marginBottom="8dp" />

        <!-- Run Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardRun"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:text="🏃"
                    android:textSize="24sp"
                    android:gravity="center" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Running"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#222222" />

                    <TextView
                        android:id="@+id/tvRunSummary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tap to start a run"
                        android:textSize="13sp"
                        android:textColor="#888888" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textSize="24sp"
                    android:textColor="@color/blue" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Water Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardWater"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:text="💧"
                        android:textSize="24sp"
                        android:gravity="center" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Water Intake"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#222222" />

                        <TextView
                            android:id="@+id/tvWaterSummary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 / 8 glasses"
                            android:textSize="13sp"
                            android:textColor="#888888" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textSize="24sp"
                        android:textColor="@color/blue" />
                </LinearLayout>

                <!-- Water Progress Bar -->
                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/waterProgressBar"
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:layout_marginTop="8dp"
                    android:progress="0"
                    app:trackCornerRadius="3dp"
                    app:indicatorColor="@color/blue"
                    app:trackColor="#E0E0E0" />

                <!-- Quick Log Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnQuickWater"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginTop="8dp"
                    android:text="+1 Glass"
                    android:textSize="12sp"
                    android:backgroundTint="@color/blue"
                    android:textColor="@color/white"
                    app:cornerRadius="8dp"
                    android:layout_gravity="end" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Sleep Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardSleep"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:text="😴"
                        android:textSize="24sp"
                        android:gravity="center" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sleep"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#222222" />

                        <TextView
                            android:id="@+id/tvSleepSummary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="No sleep logged"
                            android:textSize="13sp"
                            android:textColor="#888888" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textSize="24sp"
                        android:textColor="@color/blue" />
                </LinearLayout>

                <!-- Sleep Progress Bar -->
                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/sleepProgressBar"
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:layout_marginTop="8dp"
                    android:progress="0"
                    app:trackCornerRadius="3dp"
                    app:indicatorColor="@color/purple"
                    app:trackColor="#E0E0E0" />

                <!-- Quick Log Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnQuickSleep"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginTop="8dp"
                    android:text="+1 Hour"
                    android:textSize="12sp"
                    android:backgroundTint="@color/purple"
                    android:textColor="@color/white"
                    app:cornerRadius="8dp"
                    android:layout_gravity="end" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Steps Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardSteps"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:text="👟"
                        android:textSize="24sp"
                        android:gravity="center" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Steps"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#222222" />

                        <TextView
                            android:id="@+id/tvStepsSummary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 / 2500 steps"
                            android:textSize="13sp"
                            android:textColor="#888888" />

                        <TextView
                            android:id="@+id/tvStepsDistance"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0.0 km"
                            android:textSize="12sp"
                            android:textColor="#888888" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textSize="24sp"
                        android:textColor="@color/blue" />
                </LinearLayout>

                <!-- Steps Progress Bar -->
                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/stepsProgressBar"
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:layout_marginTop="8dp"
                    android:progress="0"
                    app:trackCornerRadius="3dp"
                    app:indicatorColor="@color/green_500"
                    app:trackColor="#E0E0E0" />

                <!-- View Details Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnViewSteps"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginTop="8dp"
                    android:text="View Details"
                    android:textSize="12sp"
                    android:backgroundTint="@color/green_500"
                    android:textColor="@color/white"
                    app:cornerRadius="8dp"
                    android:layout_gravity="end" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Daily Reward Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDailyReward"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:text="🎁  Claim Daily Reward"
            android:textSize="15sp"
            android:backgroundTint="@color/yellow"
            android:textColor="#222222" />

    </LinearLayout>
</ScrollView>
