<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#FFFFFF"
    tools:context=".fragments.SettingsFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tvAccountSettings"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:text="Account Settings"
            android:textSize="18sp"
            android:textColor="#222222"
            android:background="?attr/selectableItemBackground"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvNotificationSettings"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:text="Notification Settings"
            android:textSize="18sp"
            android:textColor="#222222"
            android:background="?attr/selectableItemBackground"
            app:layout_constraintTop_toBottomOf="@+id/tvAccountSettings"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvPrivacySettings"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:text="Privacy &amp; Security"
            android:textSize="18sp"
            android:textColor="#222222"
            android:background="?attr/selectableItemBackground"
            app:layout_constraintTop_toBottomOf="@+id/tvNotificationSettings"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <View
            android:id="@+id/divider1"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_marginTop="8dp"
            android:background="#E0E0E0"
            app:layout_constraintTop_toBottomOf="@+id/tvPrivacySettings"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvUnitsLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:padding="16dp"
            android:text="Units"
            android:textSize="18sp"
            android:textColor="#222222"
            app:layout_constraintTop_toBottomOf="@+id/divider1"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/tvUnitsDisplay"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:text="km"
            android:textSize="16sp"
            android:textColor="#888888"
            android:gravity="end"
            android:background="?attr/selectableItemBackground"
            app:layout_constraintTop_toBottomOf="@+id/divider1"
            app:layout_constraintStart_toEndOf="@+id/tvUnitsLabel"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvThemeLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:text="Theme"
            android:textSize="18sp"
            android:textColor="#222222"
            app:layout_constraintTop_toBottomOf="@+id/tvUnitsDisplay"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/tvThemeDisplay"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:text="System Default"
            android:textSize="16sp"
            android:textColor="#888888"
            android:gravity="end"
            android:background="?attr/selectableItemBackground"
            app:layout_constraintTop_toBottomOf="@+id/tvUnitsDisplay"
            app:layout_constraintStart_toEndOf="@+id/tvThemeLabel"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvDataSyncLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:text="Data Sync"
            android:textSize="18sp"
            android:textColor="#222222"
            app:layout_constraintTop_toBottomOf="@+id/tvThemeDisplay"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/tvDataSync"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:text="Sync Now"
            android:textSize="16sp"
            android:textColor="@color/blue"
            android:gravity="end"
            android:background="?attr/selectableItemBackground"
            app:layout_constraintTop_toBottomOf="@+id/tvThemeDisplay"
            app:layout_constraintStart_toEndOf="@+id/tvDataSyncLabel"
            app:layout_constraintEnd_toEndOf="parent"/>

        <View
            android:id="@+id/divider2"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:background="#E0E0E0"
            app:layout_constraintTop_toBottomOf="@+id/tvDataSync"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvAboutLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:padding="16dp"
            android:text="About"
            android:textSize="18sp"
            android:textColor="#222222"
            android:background="?attr/selectableItemBackground"
            app:layout_constraintTop_toBottomOf="@+id/divider2"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvLogout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:padding="16dp"
            android:text="Log Out"
            android:textSize="18sp"
            android:textColor="#FF5722"
            android:background="?attr/selectableItemBackground"
            app:layout_constraintTop_toBottomOf="@+id/tvAboutLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>