<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvChallengeIcon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="🏆"
            android:textSize="28sp"
            android:gravity="center"
            android:background="@drawable/bg_rounded_card" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/tvChallengeType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="WEEKLY"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/purple"
                android:background="#F3E8FF"
                android:padding="2dp" />

            <TextView
                android:id="@+id/tvChallengeTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="7-Day Runner"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#222222"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/tvChallengeDescription"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Run for 7 consecutive days"
                android:textSize="13sp"
                android:textColor="#888888" />

            <TextView
                android:id="@+id/tvChallengeRewards"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+200 XP | +100 🪙 | +5 💎"
                android:textSize="12sp"
                android:textColor="@color/yellow"
                android:textStyle="bold"
                android:layout_marginTop="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical">

                <ProgressBar
                    android:id="@+id/progressBarChallenge"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="8dp"
                    android:max="100"
                    android:progress="50"
                    android:progressTint="@color/blue" />

                <TextView
                    android:id="@+id/tvChallengeProgress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="5/10"
                    android:textSize="11sp"
                    android:textColor="#666666"
                    android:layout_marginStart="8dp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnJoinChallenge"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Join"
                android:textSize="12sp"
                android:backgroundTint="@color/blue"
                android:textColor="@color/white"
                app:cornerRadius="8dp"
                android:visibility="visible" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnClaimReward"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Claim"
                android:textSize="12sp"
                android:backgroundTint="@color/yellow"
                android:textColor="@color/black"
                app:cornerRadius="8dp"
                android:visibility="gone" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>