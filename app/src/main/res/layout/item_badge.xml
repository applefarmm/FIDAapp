<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <FrameLayout
            android:layout_width="64dp"
            android:layout_height="64dp">

            <ImageView
                android:id="@+id/ivBadgeIcon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_achievement_placeholder" />

            <ImageView
                android:id="@+id/ivLockOverlay"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_lock"
                android:visibility="gone" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvBadgeCategory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RUNNING"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="@color/blue"
                    android:background="#E8F0FF"
                    android:padding="2dp" />

                <TextView
                    android:id="@+id/tvBadgeRarity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RARE"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="@color/purple"
                    android:layout_marginStart="4dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvBadgeTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="First Run"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#222222"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/tvBadgeDescription"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Complete your first running session"
                android:textSize="13sp"
                android:textColor="#888888" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical">

                <ProgressBar
                    android:id="@+id/progressBarBadge"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="6dp"
                    android:max="100"
                    android:progress="50"
                    android:progressTint="@color/blue" />

                <TextView
                    android:id="@+id/tvBadgeProgress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="5/10"
                    android:textSize="11sp"
                    android:textColor="#666666"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvBadgeRewards"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rewards: +50 XP, +20 Coins"
                android:textSize="12sp"
                android:textColor="@color/yellow"
                android:textStyle="bold"
                android:layout_marginTop="4dp"
                android:visibility="gone" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>