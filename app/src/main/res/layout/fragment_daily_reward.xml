<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="#FFFFFF"
    tools:context=".fragments.DailyRewardFragment">

    <TextView
        android:id="@+id/tvRewardCalendarTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Daily Rewards"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/blue"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvStreakInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Claim rewards every day!"
        android:textSize="14sp"
        android:textColor="#888888"
        app:layout_constraintTop_toBottomOf="@+id/tvRewardCalendarTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- 7 Day Calendar Grid -->
    <LinearLayout
        android:id="@+id/llWeekCalendar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@+id/tvStreakInfo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Day 1 -->
        <LinearLayout
            android:id="@+id/day1Container"
            android:layout_width="40dp"
            android:layout_height="60dp"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginEnd="4dp"
            android:background="@drawable/bg_reward_day_current">

            <TextView
                android:id="@+id/tvDay1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/blue"/>

            <ImageView
                android:id="@+id/ivDay1"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_coin"/>
        </LinearLayout>

        <!-- Day 2 -->
        <LinearLayout
            android:id="@+id/day2Container"
            android:layout_width="40dp"
            android:layout_height="60dp"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginEnd="4dp"
            android:background="@drawable/bg_reward_day_inactive">

            <TextView
                android:id="@+id/tvDay2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2"
                android:textSize="14sp"
                android:textColor="#888888"/>

            <ImageView
                android:id="@+id/ivDay2"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_coin"/>
        </LinearLayout>

        <!-- Day 3 -->
        <LinearLayout
            android:id="@+id/day3Container"
            android:layout_width="40dp"
            android:layout_height="60dp"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginEnd="4dp"
            android:background="@drawable/bg_reward_day_inactive">

            <TextView
                android:id="@+id/tvDay3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3"
                android:textSize="14sp"
                android:textColor="#888888"/>

            <ImageView
                android:id="@+id/ivDay3"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_coin"/>
        </LinearLayout>

        <!-- Day 4 -->
        <LinearLayout
            android:id="@+id/day4Container"
            android:layout_width="40dp"
            android:layout_height="60dp"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginEnd="4dp"
            android:background="@drawable/bg_reward_day_inactive">

            <TextView
                android:id="@+id/tvDay4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="4"
                android:textSize="14sp"
                android:textColor="#888888"/>

            <ImageView
                android:id="@+id/ivDay4"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_shield"/>
        </LinearLayout>

        <!-- Day 5 -->
        <LinearLayout
            android:id="@+id/day5Container"
            android:layout_width="40dp"
            android:layout_height="60dp"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginEnd="4dp"
            android:background="@drawable/bg_reward_day_inactive">

            <TextView
                android:id="@+id/tvDay5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5"
                android:textSize="14sp"
                android:textColor="#888888"/>

            <ImageView
                android:id="@+id/ivDay5"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_coin"/>
        </LinearLayout>

        <!-- Day 6 -->
        <LinearLayout
            android:id="@+id/day6Container"
            android:layout_width="40dp"
            android:layout_height="60dp"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginEnd="4dp"
            android:background="@drawable/bg_reward_day_inactive">

            <TextView
                android:id="@+id/tvDay6"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="6"
                android:textSize="14sp"
                android:textColor="#888888"/>

            <ImageView
                android:id="@+id/ivDay6"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_gem"/>
        </LinearLayout>

        <!-- Day 7 (Special) -->
        <LinearLayout
            android:id="@+id/day7Container"
            android:layout_width="40dp"
            android:layout_height="60dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_reward_day_special">

            <TextView
                android:id="@+id/tvDay7"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="7"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/purple"/>

            <ImageView
                android:id="@+id/ivDay7"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_gem"/>
        </LinearLayout>

    </LinearLayout>

    <!-- Current Reward Display -->
    <TextView
        android:id="@+id/tvCurrentRewardDay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Day 1 Reward"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/blue"
        app:layout_constraintTop_toBottomOf="@+id/llWeekCalendar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <ImageView
        android:id="@+id/ivRewardIcon"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_marginTop="16dp"
        android:src="@drawable/ic_coin"
        app:layout_constraintTop_toBottomOf="@+id/tvCurrentRewardDay"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:tint="@color/blue"/>

    <TextView
        android:id="@+id/tvRewardAmount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="+10 Coins"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/green_500"
        app:layout_constraintTop_toBottomOf="@+id/ivRewardIcon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/btnClaimReward"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginStart="32dp"
        android:layout_marginTop="32dp"
        android:layout_marginEnd="32dp"
        android:backgroundTint="@color/blue"
        android:text="Claim Reward"
        android:textAllCaps="false"
        android:textSize="16sp"
        app:cornerRadius="12dp"
        app:layout_constraintTop_toBottomOf="@+id/tvRewardAmount"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvNextRewardLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Next Reward:"
        android:textSize="14sp"
        android:textColor="#888888"
        app:layout_constraintTop_toBottomOf="@+id/btnClaimReward"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvNextRewardPreview"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Day 2: +15 Coins"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/blue"
        app:layout_constraintTop_toBottomOf="@+id/tvNextRewardLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>